# Strappy-backup — environment configuration
#
# Copy this file to `.env` and fill in your token:
#     cp .env.example .env
# `.env` is gitignored so your token never gets committed.

# ---------------------------------------------------------------------------
# Where the mirror store ("the backups") lives.
# The design defaults STRAPPY_HOME to ~/.strappy, but in this environment we
# keep all backups under /repo/backups. Everything strappy owns lives here:
#   /repo/backups/config.json   /repo/backups/state.json
#   /repo/backups/secrets/      /repo/backups/mirrors/<owner>/<repo>.git
#   /repo/backups/logs/
# ---------------------------------------------------------------------------
STRAPPY_HOME=/repo/backups

# ---------------------------------------------------------------------------
# GitHub Personal Access Token.
#
# Recommended: a FINE-GRAINED PAT (https://github.com/settings/tokens?type=beta)
# with READ-ONLY access to the repositories you want backed up:
#     Repository permissions ->  Contents: Read-only
#                                Metadata: Read-only   (auto-selected)
# A classic PAT with the `repo` scope also works.
#
# (Read/WRITE "Contents" is only needed later for relay push — Milestone 3.
#  Milestone 1, the backup engine, never writes to GitHub.)
#
# This is the primary variable strappy looks for:
STRAPPY_GITHUB_TOKEN=github_pat_REPLACE_WITH_YOUR_TOKEN

# Optional fallback: if STRAPPY_GITHUB_TOKEN is unset, strappy also reads
# GITHUB_TOKEN. Leave commented unless you prefer this name.
# GITHUB_TOKEN=ghp_REPLACE_WITH_YOUR_TOKEN
